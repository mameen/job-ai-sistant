# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
dist/
build/

# ── Local environment (templates: .env.example — never commit real .env) ─────
.env
.env.local
.env.*.local
!.env.example

# ── Local config overrides (templates: *.local.yaml.example) ─────────────────
**/hermes_roles.local.yaml
**/config.local.yaml
**/*.local.yaml
!**/*.local.yaml.example

# ── Credential JSON drops (templates: *.example.json in kb/scaffold/…/secrets/)
**/private/secrets/*.json
!**/private/secrets/*.example.json
**/vault.json
*.credentials.json
*_credentials.json

# Hermes local state (never commit)
agentic/hermes/.runtime/
agentic/hermes/.kb/
agentic/hermes/.generated/

# Legacy repo-root KB (deprecated — use agentic/hermes/.kb/)
.kb/
career_kb/
.cache/

# Secrets (misc)
.API_KEY
*.pem

# OS / editor
.DS_Store
.idea/
.vscode/

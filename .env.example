# Career Intelligence — local overrides (SAFE TEMPLATE — no secrets)
#
#   cp .env.example .env
#   # edit .env with your values ( .env is gitignored )
#   python agentic/hermes/admin/manage.py setup
#
# Priority: .env / shell env  →  hermes_roles.yaml (+ optional .local.yaml)  →  defaults

# ── Ollama target ────────────────────────────────────────────────────────────
# local  = laptop defaults from hermes_roles.yaml ``ollama:``
# remote = use ``ollama_remote:`` block (set base_url in .env or hermes_roles.local.yaml)
OLLAMA_TARGET=local

# ── Explicit Ollama overrides (optional — leave empty to use yaml defaults) ─
OLLAMA_BASE_URL=
OLLAMA_MODEL=
OLLAMA_CONTEXT_LENGTH=
# OLLAMA_PROVIDER=custom

# Remote GPU example (uncomment and set your LAN host):
# OLLAMA_TARGET=remote
# OLLAMA_BASE_URL=http://192.168.0.100:11434/v1
# OLLAMA_MODEL=qwen3.6:35b
# OLLAMA_CONTEXT_LENGTH=262144

# Embedding model for KB RAG (ollama pull nomic-embed-text)
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EMBED_BASE_URL=

# ── Secrets vault (optional — or enter at manage.py secrets prompt) ──────────
# CAREER_VAULT_PASSPHRASE=
